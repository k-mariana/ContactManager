@model IEnumerable<ContactManager.Models.DTO.ContactDto>
@{
    ViewData["Title"] = "Contacts";
}
<div class="container py-4">
    <h2 class="mb-3">Contact Manager</h2>

    <div class="mb-3">
        <form asp-action="Upload" asp-controller="Contact" method="post" enctype="multipart/form-data" class="row gy-2 gx-2 align-items-center">
            @Html.AntiForgeryToken()
            <div class="col-auto">
                <input type="file" name="file" accept=".csv" class="form-control" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Upload CSV</button>
            </div>
        </form>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Warn"] != null)
    {
        <div class="alert alert-warning" style="white-space:pre-wrap">@TempData["Warn"]</div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info">@TempData["Info"]</div>
    }

    <div class="card">
        <div class="card-body">
            <div class="row g-2 mb-2">
                <div class="col-auto">
                    <input id="globalFilter" class="form-control" placeholder="Filter all columns…" />
                </div>
                <div class="col-auto">
                    <button id="clearFilter" class="btn btn-outline-secondary">Clear</button>
                </div>
            </div>

            <div class="table-responsive">
                <table id="contactsTable" class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th data-key="Id">Id</th>
                            <th data-key="Name">Name</th>
                            <th data-key="DateOfBirth">Date of birth</th>
                            <th data-key="Married">Married</th>
                            <th data-key="Phone">Phone</th>
                            <th data-key="Salary">Salary</th>
                            <th>Actions</th>
                        </tr>
                        <tr class="table-light">
                            <th></th>
                            <th><input class="form-control form-control-sm column-filter" data-key="Name" placeholder="Filter…" /></th>
                            <th><input class="form-control form-control-sm column-filter" data-key="DateOfBirth" placeholder="YYYY-MM-DD" /></th>
                            <th>
                                <select class="form-select form-select-sm column-filter" data-key="Married">
                                    <option value="">All</option>
                                    <option>true</option>
                                    <option>false</option>
                                </select>
                            </th>
                            <th><input class="form-control form-control-sm column-filter" data-key="Phone" placeholder="Filter…" /></th>
                            <th><input class="form-control form-control-sm column-filter" data-key="Salary" placeholder=">=5000" /></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {   
                            @foreach (var c in Model)
                            {
                                <tr data-id="@c.Id">
                                    <td>@c.Id</td>
                                    <td class="cell" data-key="Name">@c.Name</td>
                                    <td class="cell" data-key="DateOfBirth">@c.DateOfBirth?.ToString("yyyy-MM-dd")</td>
                                    <td class="cell" data-key="Married">@c.Married.ToString().ToLower()</td>
                                    <td class="cell" data-key="Phone">@c.Phone</td>
                                    <td class="cell" data-key="Salary">@c.Salary?.ToString("0.00")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary edit">Edit</button>
                                        <button class="btn btn-sm btn-outline-danger delete">Delete</button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center">No contacts found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div id="pagination"></div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="~/css/contacts.css" asp-append-version="true" />
<script src="/js/contacts.js"></script>